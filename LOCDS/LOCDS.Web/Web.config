<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler,log4net" />
  </configSections>

  <appSettings>
    <!-- Active environment switch -->
    <add key="Environment:Current" value="DEV" />

    <!-- Environment-specific endpoints/config values -->
    <add key="Environment:DEV:ApiBaseUrl" value="https://dev-api.contoso.local" />
    <add key="Environment:UAT:ApiBaseUrl" value="https://uat-api.contoso.local" />
    <add key="Environment:PROD:ApiBaseUrl" value="https://api.contoso.com" />

    <add key="Environment:DEV:FeatureFlags" value="VerboseDiagnostics=true;EnableSandboxBureau=true" />
    <add key="Environment:UAT:FeatureFlags"
      value="VerboseDiagnostics=false;EnableSandboxBureau=false" />
    <add key="Environment:PROD:FeatureFlags"
      value="VerboseDiagnostics=false;EnableSandboxBureau=false" />
    <add key="Demo:ShowSqlHealthBanner" value="true" />
    <add key="Demo:FailFastOnSqlError" value="false" />
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
  </appSettings>

  <connectionStrings>
    <add
      name="LOCDSConnection"
      connectionString="Server=np:\\.\pipe\MSSQL$SQLEXPRESS\sql\query;Database=LOCDS_MODEB_MIRROR;Integrated Security=True;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=True;"
      providerName="System.Data.SqlClient" />

    <add
      name="SessionStateDb"
      connectionString="Server=.\SQLEXPRESS;Database=ASPState;Integrated Security=True;Encrypt=False;TrustServerCertificate=True;"
      providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="false" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" requestValidationMode="4.5"
      encoderType="System.Web.Security.AntiXss.AntiXssEncoder, System.Web, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a" />

    <authentication mode="Forms">
      <forms
        loginUrl="~/Login.aspx"
        timeout="30"
        slidingExpiration="true"
        protection="All"
        requireSSL="false"
        cookieless="UseCookies" />
    </authentication>

    <authorization>
      <!-- Default: authenticated users only -->
      <deny users="?" />
      <allow users="*" />
    </authorization>

    <customErrors mode="Off" defaultRedirect="~/Errors/500.aspx"
      redirectMode="ResponseRewrite">
      <error statusCode="403" redirect="~/Errors/403.aspx" />
      <error statusCode="404" redirect="~/Errors/404.aspx" />
      <error statusCode="500" redirect="~/Errors/500.aspx" />
    </customErrors>

    <sessionState
      mode="InProc"
      timeout="30"
      cookieless="UseCookies"
      regenerateExpiredSessionId="true" />

    <pages controlRenderingCompatibilityVersion="4.0" clientIDMode="Predictable" />

    <httpModules />

    <httpHandlers />

    <httpCookies httpOnlyCookies="true" requireSSL="false" sameSite="Lax" />

    <machineKey
      validationKey="AutoGenerate,IsolateApps"
      decryptionKey="AutoGenerate,IsolateApps"
      validation="HMACSHA256"
      decryption="AES" />
  </system.web>

  <!-- Role-based authorization examples -->
  <location path="Login.aspx">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="Errors">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="Admin">
    <system.web>
      <authorization>
        <allow roles="Administrators" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="Underwriting">
    <system.web>
      <authorization>
        <allow roles="Administrators,Underwriters" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="Reports">
    <system.web>
      <authorization>
        <allow roles="Administrators,Auditors" />
        <deny users="*" />
      </authorization>
    </system.web>
  </location>

  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />

    <handlers />

    <modules runAllManagedModulesForAllRequests="true" />

    <httpErrors errorMode="DetailedLocalOnly" existingResponse="PassThrough">
      <remove statusCode="403" subStatusCode="-1" />
      <remove statusCode="404" subStatusCode="-1" />
      <remove statusCode="500" subStatusCode="-1" />
      <error statusCode="403" path="/Errors/403.aspx" responseMode="ExecuteURL" />
      <error statusCode="404" path="/Errors/404.aspx" responseMode="ExecuteURL" />
      <error statusCode="500" path="/Errors/500.aspx" responseMode="ExecuteURL" />
    </httpErrors>

    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Content-Security-Policy"
          value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://code.jquery.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data:; font-src 'self' data: https://cdn.jsdelivr.net; frame-ancestors 'self'; base-uri 'self'; form-action 'self';" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>

    <rewrite>
      <rules>
        <rule name="Force HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_HOST}" pattern="^(localhost|127\.0\.0\.1|\[::1\])(:\d+)?$"
              negate="true" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>

  <log4net>
    <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
      <file value="App_Data\\Logs\\locds.log" />
      <appendToFile value="true" />
      <rollingStyle value="Composite" />
      <datePattern value="yyyyMMdd'.log'" />
      <maxSizeRollBackups value="30" />
      <maximumFileSize value="20MB" />
      <staticLogFileName value="false" />
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern
          value="%date %-5level [%property{CorrelationId}] %logger - %message%newline%exception" />
      </layout>
    </appender>

    <root>
      <level value="INFO" />
      <appender-ref ref="RollingFileAppender" />
    </root>
  </log4net>

  <runtime>
    <gcServer enabled="true" />
  </runtime>
</configuration>